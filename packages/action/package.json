{
  "name": "@claims-ledger/action",
  "version": "0.2.0",
  "private": true,
  "description": "auto-ledger-verify \u2014 GitHub Action that diffs the Claims Ledger and fails CI on stale anchors.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@claims-ledger/edt": "0.2.0",
    "@claims-ledger/ledger-core": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
