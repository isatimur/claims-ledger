{
  "name": "@claims-ledger/edt",
  "version": "1.0.0",
  "description": "edt \u2014 Evidence Decision Trace. A CLI that makes agents (and humans) anchor every claim and decision to a verifiable source, and fails CI when anchors go stale.",
  "license": "MIT",
  "homepage": "https://isatimur.github.io/claims-ledger/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isatimur/claims-ledger.git",
    "directory": "packages/edt"
  },
  "bugs": {
    "url": "https://github.com/isatimur/claims-ledger/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "edt": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');const p='dist/cli.js';fs.writeFileSync(p,'#!/usr/bin/env node\\n'+fs.readFileSync(p,'utf8'));fs.chmodSync(p,0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@claims-ledger/ledger-core": "1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
